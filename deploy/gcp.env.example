# Copy values into Cloud Run env vars / Secret Manager (do not commit secrets).

# --- API service (archsari-api) ---
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@/architecture_planner?host=/cloudsql/PROJECT:REGION:INSTANCE
CORS_ALLOW_ORIGINS=https://YOUR-WEB-SERVICE.run.app
FRONTEND_URL=https://YOUR-WEB-SERVICE.run.app
GOOGLE_REDIRECT_URI=https://YOUR-WEB-SERVICE.run.app/api/auth/google/callback
GOOGLE_CLIENT_ID=
SESSION_COOKIE_SECURE=true
OPENAI_MODEL=gpt-4o-mini

# Store in Secret Manager (referenced as openai-api-key, jwt-secret, google-client-secret):
# OPENAI_API_KEY=
# JWT_SECRET=
# GOOGLE_CLIENT_SECRET=

# --- Web service (archsari-web) ---
BACKEND_URL=https://YOUR-API-SERVICE.run.app
