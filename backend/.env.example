# Copy to .env and adjust as needed.

# Local dev default is SQLite (no server required).
# For PostgreSQL use, e.g.:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/architecture_planner
DATABASE_URL=sqlite:///./architecture_planner.db

# Origins allowed to call the API (comma-separated). Vite dev server default below.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI architecture generation (required for /generate)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# AI generation object storage (request.json / response.json per run)
OBJECT_STORAGE_PROVIDER=gcs
OBJECT_STORAGE_BUCKET=archsari-generations-prod
# Optional: pin GCP project (Cloud Run usually infers this from the service account)
GCS_PROJECT_ID=
# Optional: only if OBJECT_STORAGE_PROVIDER=local (offline dev without GCS)
# OBJECT_STORAGE_LOCAL_ROOT=./object-storage

# Google OAuth (create Web application client in Google Cloud Console)
# Redirect URI must match exactly — use Vite dev URL so session cookies work via proxy:
#   http://localhost:5173/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/auth/google/callback
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=10080
FRONTEND_URL=http://localhost:5173
SESSION_COOKIE_NAME=auth_session
# true on Cloud Run (HTTPS). false for local http://localhost
SESSION_COOKIE_SECURE=false

# Cloud Run + Cloud SQL (unix socket via Cloud SQL Auth Proxy sidecar / connector):
# DATABASE_URL=postgresql+psycopg://USER:PASS@/architecture_planner?host=/cloudsql/PROJECT:REGION:INSTANCE
